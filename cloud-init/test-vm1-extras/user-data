#cloud-config
hostname: test-vm1
manage_etc_hosts: true

users:
  - name: labuser
    # Template-only default: replace with an operator key before use.
    sudo: ALL=(ALL) ALL
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - "ssh-ed25519 REPLACE_WITH_OPERATOR_PUBLIC_KEY xdr-lab-operator"

ssh_pwauth: false
disable_root: false

packages:
  - qemu-guest-agent
  - net-tools
  - tcpdump
  - curl
  - openssh-server

runcmd:
  - systemctl enable --now ssh
  - systemctl enable --now qemu-guest-agent
