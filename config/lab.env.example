# xdr-lab-appliance — example environment file.
#
# Copy to lab.env and edit. lab.env is .gitignore'd.
# Source from a shell: `set -a; . config/lab.env; set +a`
# or pass to systemd / virsh wrappers via EnvironmentFile=.
#
# All values mirror the defaults in config/paths.sh — set here to override.

# Repository root (canonical install location).
XDR_LAB_PROJECT_ROOT="/home/aella/xdr-lab-appliance"

# Runtime install target (where cli-installer.sh places assets).
XDR_BASE="/opt/xdr-lab"
XDR_ROOT="/opt/xdr-lab"

# Libvirt image pool.
LIBVIRT_IMAGE_DIR="/var/lib/libvirt/images"
UBUNTU_CLOUD_BASE_IMG="/var/lib/libvirt/images/ubuntu-24.04-cloud.img"

# Lab network.
LAB_BRIDGE="br0"
LAB_OVS_NETWORK="ovs-net"
LAB_SUBNET_CIDR="10.10.10.0/24"
LAB_GATEWAY="10.10.10.1"
LAB_DNS="10.10.10.1"

# CALDERA REST API (scenario list / agent deploy). Auto-loaded from api_key_file when unset.
# XDR_CALDERA_API_KEY=""
# Populated by: sudo bootstrap/ensure-caldera-api-key.sh → /etc/xdr-lab/caldera-api-key

# victim-linux cloud-init validation (xdr-lab-vm-manager.sh).
# VICTIM_LINUX_MATERIALIZED_IP="10.10.10.20"
# VICTIM_LINUX_SSH_PASSWORD_USER="labuser"
# VICTIM_LINUX_PASSWORD="lab1234"
# VICTIM_LINUX_SSH_USER="labuser"
# XDR_LAB_SKIP_REBOOT_TEST=0
# XDR_LAB_VICTIM_LINUX_FORCE_REDEPLOY=0
# XDR_LAB_VICTIM_LINUX_CLOUD_INIT_CLEAN=0
# XDR_LAB_LINUX_SERVER_AUTHORIZED_KEYS="/etc/xdr-lab/operator.keys"
# windows-victim SSH probe user (golden image contract):
# XDR_LAB_WINDOWS_SSH_USER="labuser"
